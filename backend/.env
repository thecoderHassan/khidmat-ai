# KhidmatAI Backend Environment Variables

# Gemini API (used by Abdul Rehman's Agent 1)
GEMINI_API_KEY=AIzaSyB8XhVE35-4eOjMfCJvpsaxw0dKcVC6ftQ
MOCK_INTENT=false

# Google Maps Distance Matrix API (optional — Agent 2 falls back to haversine)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
